<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="simple_splash_view_background">#000000</color>
    <color name="simple_splash_view_indicator">#FFFFFF</color>
    <color name="simple_splash_view_text">#FFFFFF</color>
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>
    <style name="EasySplashTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowSplashScreenBackground">@color/simple_splash_view_background</item>
        <item name="android:windowBackground">@color/simple_splash_view_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
    <style name="Theme.App" parent="AppTheme"/>
    <style name="Theme.Splash" parent="EasySplashTheme"/>
</resources>